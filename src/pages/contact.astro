---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact | Schedule a Free Consultation | Maren Voss, LMFT"
  description="Schedule a free 15-minute phone consultation with Maren Voss, LMFT. Oakland office and California telehealth available."
>
  <Header slot="header" />

  <!-- Interior Page Hero -->
  <section class="interior-hero section-dark section">
    <div class="container">
      <h1 class="heading-page">Get in Touch</h1>
      <p class="interior-hero__tagline">The first step is a conversation.</p>
    </div>
  </section>

  <!-- Consultation Booking -->
  <section class="booking section-cream section">
    <div class="container">
      <h2 class="heading-section booking__heading">Schedule a Free Consultation</h2>
      <div class="body-text booking__text fade-in-up">
        <p>The best way to get started is a free 15-minute phone consultation. We'll talk about what you're looking for, I'll share a bit about how I work, and we'll figure out together if it's a good fit.</p>
        <p>No preparation needed. No commitment required. Just a conversation.</p>
      </div>

      <div class="booking__widget-placeholder">
        <span>SimplePractice booking widget will be embedded here</span>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-section fade-in-up" id="contact-form-section">
        <h2 class="heading-section contact-form__heading">Not ready to book?</h2>
        <p class="contact-form__subtext">Send me a message and I'll get back to you within one business day.</p>
        <form class="contact-form" id="contact-form" novalidate>
          <div class="contact-form__field">
            <label for="contact-name" class="contact-form__label">Name</label>
            <input type="text" id="contact-name" name="name" class="contact-form__input" />
            <span class="contact-form__error" id="error-name">Please enter your name.</span>
          </div>
          <div class="contact-form__field">
            <label for="contact-email" class="contact-form__label">Email</label>
            <input type="email" id="contact-email" name="email" class="contact-form__input" />
            <span class="contact-form__error" id="error-email">Please enter a valid email address.</span>
          </div>
          <div class="contact-form__field">
            <label for="contact-message" class="contact-form__label">Message</label>
            <textarea id="contact-message" name="message" rows="4" class="contact-form__input contact-form__textarea"></textarea>
            <span class="contact-form__error" id="error-message">Please enter a message.</span>
          </div>
          <button type="submit" class="btn contact-form__submit" id="contact-submit">Send Message</button>
        </form>
        <div class="contact-form__confirmation" id="contact-confirmation">
          <h2 class="heading-section">Message sent.</h2>
          <p>Thank you for reaching out. In a real practice, you would hear back within one business day.</p>
        </div>
      </div>

      <!-- Other Ways to Reach Me -->
      <h2 class="heading-section contact-info__heading">Other Ways to Reach Me</h2>
      <div class="contact-grid">
        <div class="contact-grid__item">
          <h3 class="heading-sub">Phone</h3>
          <a href="tel:+15105550173" class="contact-grid__link text-link-light">(510) 555-0173</a>
        </div>
        <div class="contact-grid__item">
          <h3 class="heading-sub">Email</h3>
          <a href="mailto:maren@marenvosstherapy.com" class="contact-grid__link text-link-light">maren@marenvosstherapy.com</a>
        </div>
        <div class="contact-grid__item">
          <h3 class="heading-sub">Office</h3>
          <p>5432 College Ave, Suite 204<br />Oakland, CA 94618</p>
          <p class="contact-grid__detail">Rockridge neighborhood, one block from Rockridge BART</p>
        </div>
        <div class="contact-grid__item">
          <h3 class="heading-sub">In-Person &amp; Telehealth</h3>
          <p>I see clients in person at my Oakland office and via secure video across California. If you're outside the East Bay, telehealth is a convenient option.</p>
        </div>
        <div class="contact-grid__item">
          <h3 class="heading-sub">Hours</h3>
          <p>Monday through Thursday, 9am&ndash;6pm</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="expect section-dark section">
    <div class="container">
      <h2 class="heading-section expect__heading">After you book a consultation, here's what happens:</h2>
      <div class="body-text expect__content fade-in-up">
        <p>You'll get a confirmation email with the phone number I'll call you from. At our scheduled time, we'll talk for about 15 minutes. I'll ask what's bringing you to therapy and what you're hoping for. You can ask me anything.</p>
        <p>If we both feel like it's a good fit, I'll send you intake paperwork through my secure client portal. You'll complete it before our first session. Then we begin.</p>
        <p>If I'm not the right fit, I'll say so honestly and do my best to point you toward someone who is.</p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Booking */
  .booking__heading {
    max-width: var(--content-width);
    margin: 0 auto 24px;
  }

  .booking__text p {
    margin-bottom: 20px;
  }

  .booking__text p:last-child {
    margin-bottom: 0;
  }

  .booking__widget-placeholder {
    margin: 48px auto 80px;
    border: 1px solid var(--text-muted);
    padding: 48px;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: var(--content-width);
  }

  .booking__widget-placeholder span {
    font-family: var(--font-sans);
    font-size: var(--body-small);
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  /* Contact Info */
  .contact-info__heading {
    max-width: var(--content-width);
    margin: 0 auto 40px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px 64px;
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .contact-grid__item h3 {
    margin-bottom: 8px;
  }

  .contact-grid__item p {
    font-size: var(--body-small);
    line-height: 1.7;
    color: var(--text-muted);
  }

  .contact-grid__link {
    font-size: var(--body-small);
    line-height: 1.7;
  }

  .contact-grid__detail {
    margin-top: 8px;
    font-size: var(--caption);
    color: var(--text-muted);
  }

  /* Contact Form */
  .contact-form-section {
    max-width: var(--content-width);
    margin: 0 auto 80px;
  }

  .contact-form__heading {
    margin-bottom: 12px;
  }

  .contact-form__subtext {
    font-size: var(--body-small);
    color: var(--text-muted);
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contact-form__label {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--caption);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text-dark);
    margin-bottom: 8px;
  }

  .contact-form__input {
    width: 100%;
    padding: 12px 16px;
    font-family: var(--font-sans);
    font-size: var(--body-small);
    color: var(--text-dark);
    background-color: var(--white);
    border: 1px solid var(--text-muted);
    transition: border-color 200ms ease;
  }

  .contact-form__input:focus {
    outline: none;
    border-color: var(--terracotta);
  }

  .contact-form__textarea {
    resize: vertical;
  }

  .contact-form__error {
    display: none;
    font-family: var(--font-sans);
    font-size: var(--caption);
    color: var(--terracotta);
    margin-top: 6px;
  }

  .contact-form__field.has-error .contact-form__error {
    display: block;
  }

  .contact-form__field.has-error .contact-form__input {
    border-color: var(--terracotta);
  }

  .contact-form__submit {
    align-self: flex-start;
  }

  .contact-form__submit:disabled {
    opacity: 0.6;
    cursor: default;
  }

  .contact-form__confirmation {
    display: none;
    opacity: 0;
    transition: opacity 400ms ease;
  }

  .contact-form__confirmation.is-visible {
    opacity: 1;
  }

  .contact-form__confirmation h2 {
    margin-bottom: 12px;
  }

  .contact-form__confirmation p {
    font-size: var(--body-small);
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* What to Expect */
  .expect__heading {
    max-width: var(--content-width);
    margin: 0 auto 32px;
  }

  .expect__content p {
    margin-bottom: 24px;
  }

  .expect__content p:last-child {
    margin-bottom: 0;
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .contact-grid {
      gap: 40px 48px;
    }
  }

  @media (max-width: 767px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .booking__widget-placeholder {
      padding: 24px;
      margin-bottom: 60px;
    }
  }
</style>
<script src="../scripts/scroll-animations.js"></script>
<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('contact-submit') as HTMLButtonElement;
  const confirmation = document.getElementById('contact-confirmation') as HTMLElement;
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const fields = [
    { id: 'contact-name', errorId: 'error-name', validate: (v: string) => v.trim().length > 0 },
    { id: 'contact-email', errorId: 'error-email', validate: (v: string) => emailRegex.test(v.trim()) },
    { id: 'contact-message', errorId: 'error-message', validate: (v: string) => v.trim().length > 0 },
  ];

  // Clear error on input
  fields.forEach(({ id }) => {
    const input = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement;
    input.addEventListener('input', () => {
      input.closest('.contact-form__field')?.classList.remove('has-error');
    });
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    let valid = true;

    fields.forEach(({ id, validate }) => {
      const input = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement;
      const field = input.closest('.contact-form__field') as HTMLElement;
      if (!validate(input.value)) {
        field.classList.add('has-error');
        valid = false;
      } else {
        field.classList.remove('has-error');
      }
    });

    if (!valid) return;

    btn.disabled = true;
    btn.textContent = 'Sending\u2026';

    setTimeout(() => {
      form.style.transition = 'opacity 400ms ease';
      form.style.opacity = '0';
      form.addEventListener('transitionend', () => {
        form.style.display = 'none';
        confirmation.style.display = 'block';
        requestAnimationFrame(() => {
          confirmation.classList.add('is-visible');
        });
      }, { once: true });
    }, 1500);
  });
</script>
