---
interface Props {
  headline?: string;
  body?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  headline = 'Ready to begin?',
  body = `A 15-minute consultation is the simplest way to find out if we're a good fit. No pressure, no commitment.`,
  buttonText = 'Schedule a Free Consultation',
  buttonHref = '/contact',
} = Astro.props;
---

<section class="cta-section section-dark section">
  <div class="container cta-section__inner">
    <h2 class="heading-section">{headline}</h2>
    <p class="cta-section__body">{body}</p>
    <a href={buttonHref} class="btn">{buttonText}</a>
  </div>
</section>

<style>
  .cta-section__inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-section__body {
    margin: 20px 0 36px;
    font-size: var(--body);
    color: var(--text-muted-light);
    line-height: 1.7;
  }
</style>
